{
  "name": "book-buddy-beta",
  "version": "1.3.11",
  "description": "Book Buddy Beta – Manuscript organization and daily writing challenge app",
  "main": "src/main/main.js",
  "author": "Olivia Griffie",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "release:win": "node build-win.js",
    "release:mac": "node build-mac.js",
    "release:all": "node build-win.js && node build-mac.js",
    "build:all": "electron-builder --mac --win",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.2",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.oliviagriffie.bookbuddybeta",
    "productName": "Book Buddy Beta",
    "publish": {
      "provider": "github",
      "owner": "olivia-griffie",
      "repo": "book-buddy-beta",
      "releaseType": "release"
    },
    "directories": {
      "buildResources": "public",
      "output": "releases"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "public/icon.png",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
